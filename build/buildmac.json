{
  "appId": "com.sonoclipshare.uploader",
  "productName": "SonoClipShare Uploader",
  "asar": false,
  "directories": {
    "output": "dist"
  },
  "files": [
    "**/*",
    "!**/node_modules/ffprobe-static/bin/linux/**/*",
    "!**/node_modules/ffprobe-static/bin/win32/**/*",
    "!**/node_modules/ffprobe-static/bin/darwin/arm64/**/*"
  ],
  "mac": {
    "artifactName": "${productName}-${version}-x64.${ext}",
    "hardenedRuntime": true,
    "entitlements": "entitlements.mac.plist",
    "entitlementsInherit": "entitlements.mac.plist",
    "gatekeeperAssess": false,
    "identity": "Core Ultrasound, LLC (6VK3JZ7LRU)",
    "notarize": { "teamId": "6VK3JZ7LRU" },
    "target": {
      "target": "dmg",
      "arch": "x64"
    }
  }
}
