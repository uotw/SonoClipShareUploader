{
  "appId": "com.sonoclipshare.uploader",
  "productName": "SonoClipShare Uploader",
  "asar": false,
  "directories": {
    "output": "dist"
  },
  "files": [
    "**/*",
    "bin/**/*",
    "!**/node_modules/ffmpeg-static/ffmpeg",
    "!**/node_modules/ffprobe-static/bin/darwin/**/*",
    "!**/node_modules/ffprobe-static/bin/linux/**/*",
    "!**/node_modules/ffprobe-static/bin/win32/ia32/**/*"
  ],
  "win": {
    "artifactName": "${productName} Setup ${version} x64.${ext}",
    "azureSignOptions": {
      "publisherName": "Core Ultrasound, LLC",
      "endpoint": "https://eus.codesigning.azure.net/",
      "codeSigningAccountName": "coreultrasound",
      "certificateProfileName": "SonoClipShareApps"
    },
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  }
}
