{
  "name": "SonoClipShareUploader",
  "version": "2.6.3",
  "private": true,
  "description": "De-Identify and upload your ultrasound clips to sonoclipshare.com",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist-macarm": "electron-builder --config ./build/buildarm.json",
    "dist-mac64": "electron-builder --config ./build/buildmac.json",
    "dist-win64": "electron-builder --win --x64 --config ./build/buildwin64.json",
    "dist-mac-all": "electron-builder --mac --config ./build/build-mac-universal.json"
  },
  "keywords": [
    "Electron"
  ],
  "author": "Ben C. Smith, MD, FACEP",
  "license": "CC0-1.0",
  "bugs": {
    "url": "https://www.sonoclipshare.com/bugs"
  },
  "homepage": "https://www.sonoclipshare.com",
  "devDependencies": {
    "electron": "^25.1.0",
    "electron-builder": "^24.4.0"
  },
  "dependencies": {
    "@electron/remote": "^2.0.10",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "form-data": "^4.0.0",
    "jquery": "^3.5.1",
    "request": "^2.88.2"
  },
  "productName": "SonoClipShare Uploader"
}
